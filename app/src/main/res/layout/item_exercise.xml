<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_exercise"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:rippleColor="@color/green_ripple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Aksen warna kiri -->
        <View
            android:id="@+id/view_accent"
            android:layout_width="4dp"
            android:layout_height="60dp"
            android:layout_marginEnd="12dp"
            android:background="@color/green_primary" />

        <!-- Emoji ikon latihan -->
        <TextView
            android:id="@+id/tv_exercise_emoji"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="🏋️"
            android:textSize="28sp"
            android:background="@drawable/bg_emoji_circle"
            android:layout_marginEnd="14dp" />

        <!-- Konten teks -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_exercise_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Latihan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="2"
                android:ellipsize="end" />

            <com.google.android.material.chip.Chip
                android:id="@+id/tv_exercise_category"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Kategori"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                app:chipBackgroundColor="@color/green_light"
                app:chipMinHeight="28dp"
                android:checkable="false" />

            <TextView
                android:id="@+id/tv_exercise_muscle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Otot"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_exercise_equipment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧 Peralatan"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Arrow -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="24sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>