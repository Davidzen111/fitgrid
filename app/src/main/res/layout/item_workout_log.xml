<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Ikon latihan -->
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="🏋️"
            android:textSize="24sp"
            android:background="@drawable/bg_emoji_circle"
            android:layout_marginEnd="12dp" />

        <!-- Konten -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_log_exercise_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Latihan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_log_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 01/01/2025"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/tv_log_category"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:text="Kategori"
                    android:textSize="10sp"
                    app:chipBackgroundColor="@color/green_light"
                    app:chipMinHeight="24dp"
                    android:checkable="false" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_log_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 set × 12 rep @ 20kg"
                android:textSize="13sp"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_log_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ 30 menit"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_log_notes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 Catatan"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Tombol hapus -->
        <ImageButton
            android:id="@+id/btn_delete_log"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorError"
            android:contentDescription="Hapus" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>